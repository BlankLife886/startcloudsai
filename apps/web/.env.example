VITE_API_BASE_URL=/api
VITE_BROWSER_DOWNLOADS=true

# Optional: local dev Wallhaven proxy target (search/image/collections).
# Defaults to the production Worker in development; set to http://127.0.0.1:8787 for pure local API.
# VITE_WALLHAVEN_PROXY_TARGET=https://walleven-wallhaven-proxy.lcmzwq.workers.dev

# Turnstile 由线上 Worker /client/auth/config 下发，本地开发无需配置。

# Optional: direct AI temp upload endpoint. Leave empty to use /api/ai-temp-upload.
VITE_AI_TEMP_UPLOAD_URL=

# AI gateway defaults. Real provider keys belong in Worker secrets or encrypted D1.
VITE_AI_GATEWAY_BASE_URL=https://api.gptsapi.net
VITE_OPENAI_BASE_URL=https://api.gptsapi.net
VITE_ANTHROPIC_BASE_URL=https://api.gptsapi.net
VITE_GEMINI_BASE_URL=https://api.gptsapi.net
