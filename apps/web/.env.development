VITE_API_BASE_URL=/api
VITE_BROWSER_DOWNLOADS=true

# 本地开发：壁纸 search/image 与业务 API 一样走本地 wrangler（8787）
# 若本地无法访问 wallhaven.cc，可改回线上 Worker：
# VITE_WALLHAVEN_PROXY_TARGET=https://walleven-wallhaven-proxy.lcmzwq.workers.dev
VITE_WALLHAVEN_PROXY_TARGET=http://127.0.0.1:8787

# 本地开发不启用人机验证；线上由 Worker /client/auth/config 下发 Turnstile 配置。

# AI 网关统一入口（OpenAI / Claude / Gemini）
VITE_AI_GATEWAY_BASE_URL=https://api.gptsapi.net
VITE_OPENAI_BASE_URL=https://api.gptsapi.net
VITE_ANTHROPIC_BASE_URL=https://api.gptsapi.net
VITE_GEMINI_BASE_URL=https://api.gptsapi.net
VITE_AI_TEMP_UPLOAD_URL=https://vercel-ai-temp-api.vercel.app/api/ai-temp-upload

# 真实 AI provider key 放 Worker secrets，或登录后在设置页加密保存到 D1。
