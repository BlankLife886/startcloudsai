# Local development only. Copy to .env.development and keep the gateway on loopback.
APP_ENV_FILE=.env.development
APP_ENV=development
APP_SECRET=local-development-secret-change-me
ALLOWED_ORIGINS=http://localhost:8080
TRUSTED_PROXIES=172.30.10.254/32

DATABASE_URL=postgres://starclouds:starclouds@postgres:5432/starclouds
REDIS_PASSWORD=starclouds-redis-development-only
REDIS_URL=redis://:starclouds-redis-development-only@redis:6379/0
POSTGRES_PASSWORD=starclouds

C2A_BASE_URL=http://host.docker.internal:3000
C2A_API_KEY=
C2A_TIMEOUT_SECS=600

# Sub2API 的用户 API Key（不是 /admin/accounts 中的上游账号凭据）。
# Key 需要绑定启用了图片生成的 OpenAI 分组。
SUB2API_BASE_URL=http://host.docker.internal:8080
SUB2API_API_KEY=
SUB2API_CHAT_MODEL=gpt-5.4
SUB2API_IMAGE_MODEL=gpt-image-2
SUB2API_TIMEOUT_SECS=300

PUBLIC_BASE_URL=http://localhost:8080
# OAuth 应用的回调地址必须指向本地 PUBLIC_BASE_URL，不要填写生产凭据。
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SMTP_ADDR=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=starcloudsai
R2_PRESIGN_EXPIRE_SECS=3600

WORKER_CONCURRENCY=8
USER_MAX_RUNNING_TASKS=3

GATEWAY_BIND=127.0.0.1
GATEWAY_PORT=8080

# 只读套餐列表可用；支付、订单写入和 webhook 在所有环境中停用，不存在 PAYMENT_* 配置。
