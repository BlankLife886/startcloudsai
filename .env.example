# ===== 基础 =====
APP_ENV_FILE=.env
APP_ENV=production
APP_SECRET=change-me-random-64-chars            # 设置加密主密钥；生产必须改为 >=32 位随机串
ALLOWED_ORIGINS=https://ai.example.com          # 生产环境只接受 HTTPS Origin
# 可信代理 CIDR（逗号分隔）：只信任这些网段设置的 X-Forwarded-For。
# 默认为 compose 内网网段；置空 = 不信任任何代理（直连部署时使用）。
TRUSTED_PROXIES=172.30.10.254/32

# ===== 数据库 / Redis（compose 内网默认值，一般不用改）=====
DATABASE_URL=postgres://starclouds:replace-with-a-strong-password@postgres:5432/starclouds?sslmode=disable
REDIS_PASSWORD=replace-with-a-strong-redis-password
REDIS_URL=redis://:replace-with-a-strong-redis-password@redis:6379/0
POSTGRES_PASSWORD=replace-with-a-strong-password

# ===== chatgpt2api（你已部署的实例）=====
C2A_BASE_URL=https://your-c2a.example.com
C2A_API_KEY=your_auth_key_here
C2A_TIMEOUT_SECS=600

# ===== 用户登录（生产 OAuth/SMTP，不能与开发环境共用凭据）=====
PUBLIC_BASE_URL=https://ai.example.com
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SMTP_ADDR=smtp.example.com:587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com

# ===== Cloudflare R2（新建 bucket 后填写）=====
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=starcloudsai
R2_PRESIGN_EXPIRE_SECS=3600

# ===== 任务执行 =====
WORKER_CONCURRENCY=8
USER_MAX_RUNNING_TASKS=3

# ===== 网关端口 =====
# 默认只供宿主机上的 HTTPS 反向代理访问，不直接暴露公网
GATEWAY_BIND=127.0.0.1
GATEWAY_PORT=8080

# 只读套餐列表可用；支付、订单写入和 webhook 在所有环境中停用，不存在 PAYMENT_* 配置。
